<?xml version="1.0" encoding="utf-8" ?>
<manifest>
  <control namespace="SyedBilalAhmed"
           constructor="SmartLookup"
           version="1.1.0"
           display-name-key="SmartLookup_DisplayName"
           description-key="SmartLookup_Description"
           control-type="standard">

    <external-service-usage enabled="false" />

    <!-- BOUND: any Lookup field. The chip below it triggers a rich preview card on hover/focus. -->
    <property name="value"
              display-name-key="Value_DisplayName"
              description-key="Value_Description"
              of-type="Lookup.Simple"
              usage="bound"
              required="true" />

    <!-- Optional comma-separated list of attribute logical names. Highest priority
         in the field-resolution cascade — if set, overrides the Quick View Form and
         the smart defaults. Up to 6 fields are rendered in the card grid.
         Example: jobtitle,parentcustomerid,emailaddress1,telephone1 -->
    <property name="previewFields"
              display-name-key="PreviewFields_DisplayName"
              description-key="PreviewFields_Description"
              of-type="SingleLine.Text"
              usage="input"
              required="false"
              default-value="" />

    <!-- Auto-read the related entity's Quick View Form to pick fields. This is the
         RECOMMENDED way to configure SmartLookup — admins drag/drop fields in the
         standard Power Apps form designer, SmartLookup picks them up automatically. -->
    <property name="useQuickViewForm"
              display-name-key="UseQuickViewForm_DisplayName"
              description-key="UseQuickViewForm_Description"
              of-type="Enum"
              usage="input"
              required="false"
              default-value="true">
      <value name="true"  display-name-key="On_DisplayName"  description-key="On_Description">true</value>
      <value name="false" display-name-key="Off_DisplayName" description-key="Off_Description">false</value>
    </property>

    <!-- Optional name of a specific Quick View Form. If empty, the control uses
         "Information" if present, otherwise the first active QVF on the entity. -->
    <property name="quickViewFormName"
              display-name-key="QuickViewFormName_DisplayName"
              description-key="QuickViewFormName_Description"
              of-type="SingleLine.Text"
              usage="input"
              required="false"
              default-value="" />

    <!-- Optional accent colour (hex), used for the avatar gradient + secondary chip. -->
    <property name="accentColor"
              display-name-key="AccentColor_DisplayName"
              description-key="AccentColor_Description"
              of-type="SingleLine.Text"
              usage="input"
              required="false"
              default-value="" />

    <!-- Card position relative to the lookup chip. Auto picks the best fit. -->
    <property name="position"
              display-name-key="Position_DisplayName"
              description-key="Position_Description"
              of-type="Enum"
              usage="input"
              required="false"
              default-value="auto">
      <value name="auto"   display-name-key="Position_Auto"   description-key="Position_Auto_Desc">auto</value>
      <value name="below"  display-name-key="Position_Below"  description-key="Position_Below_Desc">below</value>
      <value name="above"  display-name-key="Position_Above"  description-key="Position_Above_Desc">above</value>
      <value name="right"  display-name-key="Position_Right"  description-key="Position_Right_Desc">right</value>
    </property>

    <!-- Show "Open record" button at the bottom of the card. -->
    <property name="showOpenButton"
              display-name-key="ShowOpenButton_DisplayName"
              description-key="ShowOpenButton_Description"
              of-type="Enum"
              usage="input"
              required="false"
              default-value="true">
      <value name="true"  display-name-key="On_DisplayName"  description-key="On_Description">true</value>
      <value name="false" display-name-key="Off_DisplayName" description-key="Off_Description">false</value>
    </property>

    <!-- Delay before the preview card appears (ms). Default 250. -->
    <property name="hoverDelay"
              display-name-key="HoverDelay_DisplayName"
              description-key="HoverDelay_Description"
              of-type="Whole.None"
              usage="input"
              required="false"
              default-value="250" />

    <resources>
      <code path="index.ts" order="1" />
      <css path="css/SmartLookup.css" order="1" />
      <resx path="strings/SmartLookup.1033.resx" version="1.0.0" />
    </resources>

    <!-- WebAPI is required to fetch the related record's metadata and field values. -->
    <feature-usage>
      <uses-feature name="WebAPI" required="true" />
      <uses-feature name="Utility" required="true" />
    </feature-usage>

  </control>
</manifest>
